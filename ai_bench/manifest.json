{
  "manifest_version": 3,
  "name": "[ maitrix ]",
  "version": "1.0.0",
  "description": "AI benchmark TOP N models with history sparklines from aistupidlevel.info",
  "permissions": ["storage", "alarms", "sidePanel"],
  "host_permissions": ["https://aistupidlevel.info/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "[ maitrix ]"
  },
  "side_panel": {
    "default_path": "src/panel.html"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
